{
  "enabled": true,
  "name": "Generate Spec Tests",
  "description": "On-demand hook that scans the entire js/ directory tree for JS/MJS files and generates spec tests under tests/ with matching subfolder structure. Test files are named <file>.spec.js.",
  "version": "2",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "js/**/*.js",
      "js/**/*.mjs"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Scan all .js and .mjs files under js/ (recursively, including all subdirectories). For each JS/MJS file found, write a comprehensive spec test file under the tests/ directory, mirroring the subfolder structure relative to js/. For example:\n- js/utils.js → tests/utils.spec.js\n- js/lib/helpers.js → tests/lib/helpers.spec.js\n\nFor each file:\n1. Read the source file to understand its exports, functions, and logic.\n2. Write a spec test file using plain JavaScript with a simple test runner pattern (describe/it style using console.assert or a lightweight framework if one is already configured in package.json).\n3. Cover the main exported functions with unit tests including edge cases.\n4. Name each test file as <original-filename>.spec.js.\n5. Skip files that already have a corresponding .spec.js test file.\n\nWork through all files systematically."
  }
}
